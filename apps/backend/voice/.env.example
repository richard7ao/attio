# Copy to .env (git-ignored) and fill in. Lists every var the service reads.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8787
# Public HTTPS base URL SLNG can reach (cloudflared/ngrok tunnel). Used to build
# the tool + event webhook URLs registered on the SLNG agent. Re-run
# `npm run upsert-agent` whenever this changes.
PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com
# LOG_LEVEL=info

# ── Supabase (service role / sb_secret_… — bypasses RLS; server-side only) ─────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Owner (public.users.id) for calls created without an explicit userId — required
# for the simulator and for auto-ingesting externally-started (browser) sessions.
# A demo user is seeded in Supabase with this id (see packages/db/supabase/voice.sql).
DEMO_USER_ID=00000000-0000-0000-0000-000000000001

# ── SLNG ─────────────────────────────────────────────────────────────────────
SLNG_API_BASE=https://api.agents.slng.ai
SLNG_API_KEY=
# The agent we dispatch from. Create/update it with `npm run upsert-agent`.
SLNG_AGENT_ID=
# Twilio SIP trunk the agent dials over (from the SLNG dashboard) — needed only
# for real outbound phone calls, not browser sessions.
SLNG_SIP_OUTBOUND_TRUNK_ID=
# Optional: override the agent's conversation LLM at upsert time, e.g.
#   SLNG_LLM=groq/openai/gpt-oss-120b
SLNG_LLM=
# Webhook auth. Leave BOTH blank to skip verification (events flow freely — fine
# for dev). Set them, then re-run upsert-agent, to turn on signing. The exact
# signature header below is unconfirmed; verify before enabling.
SLNG_WEBHOOK_SECRET=
SLNG_WEBHOOK_SIGNATURE_HEADER=x-slng-signature
TOOL_WEBHOOK_SECRET=

# ── Agent brain ──────────────────────────────────────────────────────────────
# Powers pre-call planning, the mid-call tool fallback, and post-call summary —
# NOT the live voice (that's SLNG's own model). One of: gemini | claude | openai | mubit.
# Unset/failed keys fall back to Claude; if that's unset too, summaries are skipped
# (transcripts still save).
AGENT_BRAIN=gemini

# Gemini (OpenAI-compatible endpoint). Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Claude
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Generic OpenAI-compatible (OpenAI, Groq, OpenRouter, …)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Mubit
# MUBIT_API_BASE=
# MUBIT_API_KEY=
# MUBIT_MODEL=
