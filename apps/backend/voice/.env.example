# ── Server ───────────────────────────────────────────────────────────────────
PORT=8787
# Public HTTPS base URL SLNG can reach (e.g. an ngrok tunnel). Used to build the
# tool + event webhook URLs we register on the SLNG agent.
PUBLIC_BASE_URL=https://your-tunnel.ngrok.app

# ── Supabase (service role — bypasses RLS; server-side only, never ship to web) ─
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── SLNG ─────────────────────────────────────────────────────────────────────
SLNG_API_BASE=https://api.agents.slng.ai
SLNG_API_KEY=
# The agent we dispatch calls from. Create/update it with `npm run upsert-agent`.
SLNG_AGENT_ID=
# Outbound SIP trunk the agent dials over (configured in SLNG dashboard).
# OPEN QUESTION: confirm whether SLNG provides this trunk or we bring Twilio SIP.
SLNG_SIP_OUTBOUND_TRUNK_ID=
# Secret used to HMAC-sign SLNG system (event) webhooks back to us.
SLNG_WEBHOOK_SECRET=dev-event-secret-change-me
# Header SLNG puts the HMAC-SHA256 signature in. TODO: confirm exact name.
SLNG_WEBHOOK_SIGNATURE_HEADER=x-slng-signature
# Bearer token SLNG sends when calling our mid-call tool webhooks.
TOOL_WEBHOOK_SECRET=dev-tool-secret-change-me

# ── Agent brain ──────────────────────────────────────────────────────────────
# Which brain powers pre-call planning, mid-call tools, post-call summary.
# "mubit" (required runtime) | "claude" (fallback so the demo always runs).
AGENT_BRAIN=claude
# Mubit (fill in once we have docs from the booth).
MUBIT_API_BASE=
MUBIT_API_KEY=
MUBIT_MODEL=
# Claude fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
