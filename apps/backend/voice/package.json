{
  "name": "@attio/voice",
  "version": "0.0.0",
  "private": true,
  "description": "Voice outreach service — orchestrates SLNG voice-agent calls for enterprise renewals & upsells.",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "tsx --env-file=.env src/server.ts",
    "typecheck": "tsc --noEmit",
    "upsert-agent": "tsx --env-file=.env scripts/upsert-agent.ts",
    "dispatch-test": "tsx --env-file=.env scripts/dispatch-test.ts",
    "demo": "tsx --env-file=.env scripts/simulate.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@supabase/supabase-js": "^2.45.4",
    "express": "^4.19.2",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
