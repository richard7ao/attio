{
  "name": "@attio/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fastify API for the Attio CRM extension.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --target node20 --clean",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@attio/db": "workspace:*",
    "@attio/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@attio/config": "workspace:*",
    "@types/node": "^22.7.4",
    "eslint": "^9.11.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
