{
  "name": "@attio/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fastify API for the Attio CRM extension.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "sync:attio": "tsx src/scripts/sync-attio.ts",
    "seed:voice": "tsx src/scripts/seed-voice.ts",
    "superlink:pool": "tsx src/scripts/superlink-pool.ts",
    "register:attio-webhooks": "tsx src/scripts/register-attio-webhooks.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@attio/db": "workspace:*",
    "@attio/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.1",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "postgres": "^3.4.4",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@attio/config": "workspace:*",
    "@types/node": "^22.7.4",
    "eslint": "^9.11.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
