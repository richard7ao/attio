      "id": "b1d9d4cf-09cb-4e24-90e5-47d7ecaa4196",
      "name": "Merge Account Data",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [912, 784]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// inputs by position from the 5 parallel Supabase fetches\nconst company   = items[0].json;  // attio_companies: id, name, domain\nconst csData    = items[1].json;  // attio_customer_success: arr, stage, health, notes\nconst churn     = items[2].json;  // company_churn: company_id, score, status, reason\n\n// company_signals rows (usage_drop), sorted newest-first\nconst usageRows = (Array.isArray(items[3].json) ? items[3].json : [items[3].json])\n  .filter(r => r && r.company_id)\n  .sort((a, b) => new Date(b.created_at) - new Date(a.created_at));\n\n// company_signals rows (support_ticket), sorted newest-first\nconst suppRows = (Array.isArray(items[4].json) ? items[4].json : [items[4].json])\n  .filter(r => r && r.company_id)\n  .sort((a, b) => new Date(b.created_at) - new Date(a.created_at));\n\n// Usage: company_signals.value holds the usage-drop magnitude (0-100);\n// metadata may carry { last_login_at, usage_pct_before, usage_pct_after }\nconst usageLatest  = usageRows[0]?.metadata?.usage_pct_after ?? usageRows[0]?.value ?? null;\nconst usageWeekAgo = usageRows[4]?.metadata?.usage_pct_after ?? usageRows[4]?.value ?? usageLatest;\nconst usageDrop    = typeof usageLatest === 'number' && typeof usageWeekAgo === 'number'\n  ? (usageWeekAgo - usageLatest).toFixed(1)\n  : 'unknown';\n\n// Days to renewal: attio_won_contracts.projected_close_date is not fetched in this flow;\n// set to null — add a 6th parallel fetch from attio_won_contracts if needed.\nconst renewalDate   = null;\nconst daysToRenewal = null;\n\n// Last contact: derived from most-recent usage signal timestamp as a proxy\nconst lastContact = usageRows[0]?.created_at\n  ? `${Math.floor((Date.now() - new Date(usageRows[0].created_at)) / (1000*60*60*24))} days ago`\n  : 'never';\n\n// Support signals: metadata shape expected: { subject, sentiment, description }\nconst negativeTickets = suppRows\n  .filter(t => t.metadata?.sentiment === 'negative')\n  .map(t => t.metadata?.subject ?? t.type)\n  .join('; ') || 'none';\n\nconst signalSummary = suppRows.length\n  ? suppRows.map(s =>\n      `[${s.source}] ${s.metadata?.description ?? s.metadata?.subject ?? s.type} (${s.metadata?.sentiment ?? 'neutral'})`\n    ).join('\\n')\n  : 'No recent support signals';\n\nreturn [{\n  json: {\n    account_id:            company.id,\n    company_name:          company.name ?? 'Unknown',\n    arr:                   csData.arr ?? 0,\n    plan_tier:             csData.stage ?? 'unknown',\n    cs_health:             csData.health ?? 'unknown',\n    cs_notes:              csData.notes ?? '',\n    renewal_date:          renewalDate,\n    days_to_renewal:       daysToRenewal,\n    // Contact fields: add a parallel fetch from attio_people WHERE company_id=account_id\n    primary_contact_name:  'N/A',\n    primary_contact_phone: 'N/A',\n    primary_contact_email: 'N/A',\n    // Owner email: add a fetch from accounts JOIN users WHERE attio_record_id=account_id\n    owner_email:           'N/A',\n    // Churn status from company_churn\n    rag_status:            churn.status ?? 'unknown',\n    health_score:          churn.score ?? 0,\n    churn_risk_flags:      churn.reason ?? 'none',\n    // Usage signals from company_signals\n    usage_latest:          usageLatest,\n    usage_drop:            usageDrop,\n    last_login:            usageRows[0]?.metadata?.last_login_at ?? 'unknown',\n    last_contact:          lastContact,\n    negative_tickets:      negativeTickets,\n    comms_summary:         signalSummary,\n  }\n}];"
      },
      "id": "0e8fb00f-b871-49bb-b67c-5716c03e290b",
      "name": "Build Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1136, 784]
