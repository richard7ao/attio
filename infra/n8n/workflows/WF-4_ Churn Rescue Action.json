    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent?key={{ $env.GEMINI_API_KEY }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\"contents\": [{\"parts\": [{\"text\": \"You are a senior enterprise customer success manager. A client account is at churn risk and you need to produce a detailed account plan to rescue them.\\n\\n## ACCOUNT DATA\\nCompany: {{ $json.company_name }}\\nARR: ${{ $json.arr }}\\nPlan / Stage: {{ $json.plan_tier }}\\nCRM Health: {{ $json.cs_health }}\\nRenewal: {{ $json.days_to_renewal !== null ? ($json.days_to_renewal + ' days away (' + $json.renewal_date + ')') : 'date not available' }}\\nChurn status: {{ $json.rag_status }} (score: {{ $json.health_score }}/100)\\nChurn reason on record: {{ $json.churn_risk_flags }}\\nCurrent usage drop magnitude: {{ $json.usage_latest !== null ? $json.usage_latest : 'no data' }}\\nUsage trend (7-day drop): {{ $json.usage_drop }}%\\nLast login: {{ $json.last_login }}\\nLast contact: {{ $json.last_contact }}\\nNegative support signals: {{ $json.negative_tickets }}\\nRecent signals:\\n{{ $json.comms_summary }}\\nCS notes: {{ $json.cs_notes }}\\nPrimary contact: {{ $json.primary_contact_name }}\\n\\n## YOUR TASK\\nGenerate a complete account rescue plan. Return ONLY valid JSON:\\n\\n{\\n  \\\"executive_summary\\\": \\\"2-3 sentence overview of the churn risk and recommended approach\\\",\\n  \\\"risk_factors\\\": [\\\"factor 1\\\", \\\"factor 2\\\"],\\n  \\\"account_plan\\\": [\\n    { \\\"action\\\": \\\"...\\\", \\\"owner\\\": \\\"CSM|AI|email\\\", \\\"timeline\\\": \\\"immediate|this week|this month\\\" }\\n  ],\\n  \\\"call_script\\\": \\\"Full natural language script for the AI voice agent. Include: greeting, empathy, specific pain point acknowledgement, value reminder, concrete offer or next step, and close. Write as spoken dialogue.\\\",\\n  \\\"objection_handling\\\": [\\n    { \\\"objection\\\": \\\"...\\\", \\\"response\\\": \\\"...\\\" }\\n  ],\\n  \\\"email_draft\\\": \\\"Full follow-up email to send after the call\\\",\\n  \\\"success_metric\\\": \\\"What outcome defines this rescue as successful\\\",\\n  \\\"priority\\\": \\\"high|medium|low\\\"\\n}\"}]}],\"generationConfig\": {\"temperature\": 0.4,\"responseMimeType\": \"application/json\"}} }}",
        "options": {}
      },
      "id": "f389ea27-7787-4940-a299-ae1e98919602",
      "name": "Gemini — Generate Account Plan",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1360, 784]
    },
    {
      "parameters": {
        "jsCode": "const raw     = $input.first().json.candidates[0].content.parts[0].text;\nconst cleaned = raw.replace(/```json|```/g, '').trim();\nconst plan    = JSON.parse(cleaned);\nconst ctx     = $('Build Context').first().json;\n\nreturn [{\n  json: {\n    ...ctx,\n    executive_summary:  plan.executive_summary,\n    risk_factors:       plan.risk_factors,\n    account_plan:       plan.account_plan,\n    call_script:        plan.call_script,\n    objection_handling: plan.objection_handling,\n    email_draft:        plan.email_draft,\n    success_metric:     plan.success_metric,\n    priority:           plan.priority,\n  }\n}];"
      },
