{
  "name": "@attio/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Drizzle ORM schema + client. SQLite in dev, Postgres (Supabase) in prod.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@attio/shared": "workspace:*",
    "better-sqlite3": "^11.3.0",
    "drizzle-orm": "^0.33.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@attio/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "drizzle-kit": "^0.24.2",
    "eslint": "^9.11.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
