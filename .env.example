# =============================================================================
# Attio — environment template
# Copy to `.env` and fill in. NEVER commit a real .env (it is gitignored).
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
# Frontend origin allowed by the API (Vite dev server default).
CORS_ORIGIN=http://localhost:5173

# ---- Database ---------------------------------------------------------------
# sqlite   -> local dev (default, zero external services)
# postgres -> prod / Supabase
DATABASE_DRIVER=sqlite
# Used when DATABASE_DRIVER=sqlite
SQLITE_PATH=./data/attio.local.db
# Used when DATABASE_DRIVER=postgres (Supabase connection string)
DATABASE_URL=

# ---- Supabase (Auth, prod) --------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Exposed to the web app (Vite only inlines VITE_-prefixed vars).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Absolute API origin the web SPA calls in prod (e.g. a cloudflared tunnel URL).
# Unset in dev -> the SPA uses the relative /api path via the Vite dev proxy.
VITE_API_BASE_URL=

# ---- Anthropic (agent reasoning / drafting) --------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ---- Twilio (voice + SMS outreach) -----------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Twilio posts delivery/voice status here:
TWILIO_WEBHOOK_URL=http://localhost:3001/api/webhooks/twilio

# ---- n8n (automation / signal ingestion) -----------------------------------
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678
# 32+ char secret; n8n encrypts stored credentials with this. Generate once.
N8N_ENCRYPTION_KEY=
GENERIC_TIMEZONE=UTC

# ---- Analysis layer: Superlink (LLM) + Mubit (agent memory) -----------------
# Superlink (Superlinked SIE gateway) is the LLM provider for the "Head of Data" agent.
# SUPERLINK_BASE_URL is the OpenAI-compatible chat base URL and MUST end in /v1.
# SUPERLINK_MODEL defaults to a model that's reliably warm on the shared default pool.
# SUPERLINK_GPU (optional) pins a dedicated hot lane via X-SIE-MACHINE-PROFILE:
#   Larger: SUPERLINK_MODEL=Qwen/Qwen3.6-27B:rtx-pro-6000  SUPERLINK_GPU=rtx6000-qwen27
#   Fast:   SUPERLINK_MODEL=Qwen/Qwen3.5-4B                SUPERLINK_GPU=rtx6000
#   Use "pool/profile" to target a dedicated pool. Empty = shared default routing.
# SUPERLINK_ADMIN_KEY: admin token for pool management / model pinning (POST /v1/pools),
#   used only by `pnpm --filter @attio/api superlink:pool` — NOT on the request path.
SUPERLINK_API_KEY=
SUPERLINK_BASE_URL=
SUPERLINK_MODEL=Qwen/Qwen3-4B-Instruct-2507
SUPERLINK_GPU=
SUPERLINK_ADMIN_KEY=
# Mubit = durable memory / managed agent layer (https://api.mubit.ai).
MUBIT_API_KEY=
MUBIT_BASE_URL=https://api.mubit.ai
MUBIT_AGENT=head-of-data

# ---- Churn-rescue orchestration (n8n WF-4) ----------------------------------
# When set, escalations POST a churn.escalated event (incl. the brief) to
# {N8N_WEBHOOK_BASE_URL}/webhook/churn-rescue/run for voice/email/queue routing.
N8N_WEBHOOK_BASE_URL=

# ---- Attio CRM --------------------------------------------------------------
# ATTIO_API_KEY needs read-write scopes for write-back: object_configuration,
# note, task, list_entry, record_permission.
ATTIO_API_KEY=
ATTIO_API_BASE_URL=https://api.attio.com/v2
ATTIO_WORKSPACE_ID=
# Churn write-back targets (data "comes up into Attio"):
ATTIO_CHURN_LIST=attio_churn
# Workspace member id to assign call tasks to; if unset, the first member is used.
ATTIO_TASK_ASSIGNEE_ID=
# Connector (Attio -> our API). Register with:
#   pnpm --filter @attio/api register:attio-webhooks https://<public-api-host>
# then set the printed secret here. VOICE_BASE_URL is where "place a call" is forwarded.
ATTIO_WEBHOOK_SECRET=
VOICE_BASE_URL=
# Demo override: when both set, syncAttio forces every contact to these so all
# outreach (calls/email) routes to one inbox/number and survives a re-sync.
DEMO_CONTACT_EMAIL=
DEMO_CONTACT_PHONE=

# ---- Stripe (churn signal: cancellation -> instant red) ---------------------
# STRIPE_API_KEY: secret (sk_test_...) or restricted (rk_test_...) test key.
# STRIPE_WEBHOOK_SECRET: from `stripe listen --forward-to localhost:3001/api/webhooks/stripe`
#   (when set, the /webhooks/stripe route verifies the Stripe-Signature header).
# STRIPE_PRICE_ID: optional; if unset the link service creates a $50/mo test price.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
